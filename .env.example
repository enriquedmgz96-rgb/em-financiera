# Nombre del contenedor PostgreSQL existente en el VPS
# (verificar con: docker inspect <nombre> | grep IPAddress)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=financiera
DB_USER=financiera_user
DB_PASSWORD=cambiar_en_produccion

# Red Docker existente donde corren n8n y PostgreSQL
# (verificar con: docker network ls)
DOCKER_NETWORK=n8n_default

PORT=3001
TZ=America/Argentina/Cordoba
